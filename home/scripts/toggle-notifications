#!/usr/bin/env sh
# Toggle manual DND on/off using mako and show a Hyprland-side cue.

NOTIFY_DIR="$HOME/.cache/mako"
MANUAL_STATE="$NOTIFY_DIR/dnd-manual"
AUTO_STATE="$NOTIFY_DIR/dnd-auto"

mkdir -p "$NOTIFY_DIR"

apply_mode() {
    makoctl mode -a dnd 2>/dev/null || true
    if [ -f "$MANUAL_STATE" ] || [ -f "$AUTO_STATE" ]; then
        makoctl mode -s dnd 2>/dev/null || true
    else
        makoctl mode -s default 2>/dev/null || true
    fi
}

hypr_notify() {
    icon="$1"
    color="$2"
    shift 2
    hyprctl notify "$icon" 1800 "$color" "$*" >/dev/null 2>&1 || true
}

if [ -f "$MANUAL_STATE" ]; then
    rm -f "$MANUAL_STATE"
    apply_mode
    notify-send "Manual DND disabled"
else
    notify-send "Manual DND enabled"
    touch "$MANUAL_STATE"
    apply_mode
fi
